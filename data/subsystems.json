{
  "version": "0.2",
  "groups": [
    {"id": "ECLSS",          "name": "ECLSS — Environmental Control & Life Support", "description": "Air, water, waste, thermal — required ECLSS integration per REQ-SYS-012/026/056."},
    {"id": "Food",           "name": "Food System",          "description": "Production, processing, storage, prep — focus of the challenge."},
    {"id": "Infrastructure", "name": "Infrastructure & ISRU","description": "Power, ISRU, structures. Sets operating envelope."},
    {"id": "Crew",           "name": "Crew & Operations",    "description": "Monitoring, control, dining."}
  ],
  "subsystems": [
    {"id": "power_generation",        "group": "Infrastructure", "name": "Power Generation", "description": "Primary electrical power for the surface habitat.", "match_categories": ["power"], "match_tags": ["power-source","solar","nuclear","rps"], "expected_outputs": ["electric_power_dc","electric_power_ac"], "expected_inputs": [], "allow_parallel": true, "owner_subteam": "ST1"},
    {"id": "isru_resources",          "group": "Infrastructure", "name": "ISRU — In-Situ Resource Utilization", "description": "Extract water, O2 from regolith and atmosphere.", "match_categories": ["isru"], "match_tags": ["isru","water-mining","moxie"], "expected_outputs": ["potable_water","irrigation_water","o2_gas","n2_gas"], "expected_inputs": ["electric_power_dc"], "allow_parallel": true, "owner_subteam": "ST1"},
    {"id": "air_revitalization",      "group": "ECLSS",          "name": "Air Revitalization", "description": "CO2 removal, O2 supply, trace contaminant control.", "match_categories": ["air_revitalization"], "expected_outputs": ["o2_gas","co2_gas","air_habitat"], "expected_inputs": ["air_habitat","potable_water","h2_gas","electric_power_dc"], "allow_parallel": true, "owner_subteam": "ST1"},
    {"id": "water_management",        "group": "ECLSS",          "name": "Water Management", "description": "Recover and polish urine/condensate/greywater into potable + irrigation.", "match_categories": ["water_recovery"], "expected_outputs": ["potable_water","irrigation_water"], "expected_inputs": ["urine_pretreated","condensate_humidity","greywater"], "allow_parallel": true, "owner_subteam": "ST1"},
    {"id": "thermal_control",         "group": "ECLSS",          "name": "Thermal Control", "description": "Heat rejection from active equipment to space.", "match_categories": ["thermal_control"], "expected_inputs": ["heat_reject_to_radiator","electric_power_dc"], "expected_outputs": [], "allow_parallel": false, "owner_subteam": "ST1"},
    {"id": "waste_management",        "group": "ECLSS",          "name": "Waste Management", "description": "Process food waste, inedible biomass, packaging, brine, human waste.", "match_categories": ["waste_processing"], "expected_outputs": ["compost_finished","digester_effluent","ch4_gas","ash_inorganic","general_trash"], "expected_inputs": ["food_waste_organic","inedible_biomass","feces_solid","brine_concentrated","food_packaging_waste"], "allow_parallel": true, "owner_subteam": "ST2"},
    {"id": "food_production_calorie", "group": "Food",           "name": "Food Production — Calorie Crops", "description": "Carbohydrate-dense bioregenerative crops.", "match_categories": ["crop_production"], "match_tags": ["calorie-crop","staple","grain"], "expected_outputs": ["edible_biomass_root","edible_biomass_grain","o2_gas","inedible_biomass"], "expected_inputs": ["electric_power_dc","co2_gas","irrigation_water","nutrient_solution","seeds"], "allow_parallel": true, "owner_subteam": "ST2"},
    {"id": "food_production_leafy",   "group": "Food",           "name": "Food Production — Leafy & Fruiting", "description": "High-morale fresh produce.", "match_categories": ["crop_production"], "match_tags": ["fresh-greens","leafy","vitamin"], "expected_outputs": ["edible_biomass_leafy","edible_biomass_fruiting","o2_gas","inedible_biomass"], "expected_inputs": ["electric_power_dc","co2_gas","irrigation_water","nutrient_solution","seeds"], "allow_parallel": true, "owner_subteam": "ST2"},
    {"id": "food_production_protein", "group": "Food",           "name": "Food Production — Protein", "description": "Protein source — microbial, fungal, insect, cellular.", "match_categories": ["microbial_production","animal_production","cellular_agriculture","fungi_production"], "expected_outputs": ["edible_biomass_microbial","edible_biomass_fungal","edible_biomass_cell_culture"], "expected_inputs": ["electric_power_dc","co2_gas","nutrient_solution","inedible_biomass","food_waste_organic"], "allow_parallel": true, "owner_subteam": "ST2"},
    {"id": "food_processing",         "group": "Food",           "name": "Food Processing & Preservation", "description": "Convert raw biomass into shelf-stable / palatable forms.", "match_categories": ["food_processing"], "expected_outputs": ["processed_food_dry","processed_food_chilled","meal_ready"], "expected_inputs": ["edible_biomass_leafy","edible_biomass_root","edible_biomass_grain","edible_biomass_microbial","edible_biomass_fungal","edible_biomass_cell_culture","edible_biomass_fruiting","electric_power_dc"], "allow_parallel": true, "owner_subteam": "ST2"},
    {"id": "food_storage",            "group": "Food",           "name": "Food Storage", "description": "Refrigerated, frozen, dry, ambient storage.", "match_categories": ["food_storage"], "expected_outputs": ["processed_food_chilled","processed_food_dry"], "expected_inputs": ["electric_power_dc","heat_reject_to_radiator"], "allow_parallel": true, "owner_subteam": "ST2"},
    {"id": "food_prep",               "group": "Food",           "name": "Food Preparation & Cooking", "description": "Heating, mixing, plating of meals.", "match_categories": ["food_prep"], "expected_outputs": ["meal_ready","voc_trace"], "expected_inputs": ["processed_food_dry","processed_food_chilled","potable_water","electric_power_dc"], "allow_parallel": true, "owner_subteam": "ST2"},
    {"id": "meal_assembly_dining",    "group": "Crew",           "name": "Meal Assembly & Dining", "description": "Plating, communal dining, cleanup.", "match_categories": ["food_prep"], "match_tags": ["dining","communal-area"], "expected_outputs": ["food_waste_organic","food_packaging_waste"], "expected_inputs": ["meal_ready"], "allow_parallel": false, "owner_subteam": "ST4"},
    {"id": "monitoring_control",      "group": "Crew",           "name": "Monitoring & Crew Tracking", "description": "Sensors, control software, intake tracking.", "match_categories": ["monitoring_control"], "expected_outputs": ["monitoring_telemetry","control_setpoint"], "expected_inputs": ["electric_power_dc"], "allow_parallel": true, "owner_subteam": "ST3"}
  ]
}
